<Window x:Class="ACRLiverManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ACR Livery Manager" Height="720" Width="1200">
    <DockPanel Margin="12">

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="10" Background="#EEE" CornerRadius="6" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusText}" />
        </Border>
        
        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Game root:" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" Text="{Binding GameRoot, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Installer root:" Margin="0,0,8,0" />
            <TextBox Grid.Column="4" Text="{Binding InstallerRoot, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="6" Content="Rescan" Command="{Binding RescanCommand}" Padding="14,6" />
        </Grid>

        <!-- Main layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Cars -->
            <GroupBox Header="Cars" Grid.Column="0" Margin="0,0,10,0">
                <ListBox ItemsSource="{Binding Cars}"
                         SelectedItem="{Binding SelectedCar}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <!-- Liveries -->
            <GroupBox Header="Liveries" Grid.Column="1" Margin="0,0,10,0">
                <ListBox ItemsSource="{Binding Liveries}"
                         SelectedItem="{Binding SelectedLivery}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,6,0,6">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding InstallState.StateText}" Opacity="0.8" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <!-- Details -->
            <GroupBox Header="Details" Grid.Column="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="{Binding SelectedLivery.DisplayName}" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedLivery.InstallState.StateText}" Opacity="0.8" />
                        <TextBlock Text="{Binding SelectedLivery.BaseName}" Opacity="0.7" FontSize="12" />
                    </StackPanel>

                    <Border Grid.Row="1" Background="#111" CornerRadius="8">
                        <Image Source="{Binding SelectedLivery.PreviewImage}" Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Install" Command="{Binding InstallCommand}" Margin="0,0,8,0" Padding="14,6" />
                        <Button Content="Activate" Command="{Binding ActivateCommand}" Margin="0,0,8,0" Padding="14,6" />
                        <Button Content="Disable" Command="{Binding DisableCommand}" Margin="0,0,8,0" Padding="14,6" />
                        <Button Content="Uninstall" Command="{Binding UninstallCommand}" Padding="14,6" />
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>
    </DockPanel>

</Window>